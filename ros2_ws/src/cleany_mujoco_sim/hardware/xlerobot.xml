  <default>
    <!-- Default: all geoms don't participate in collision -->
    <geom contype="0" conaffinity="0" condim="1" solref="0.005 1"/>
    <!-- 5-inch articulated mecanum wheel defaults. -->
    <default class="wheel">
      <!-- Drive-train losses are represented by the output-shaft DC motor curve. -->
      <joint type="hinge" axis="0 0 1" damping="0"
             actuatorfrcrange="-2.646 2.646"/>
    </default>
    <default class="pg42_drive">
      <!--
        PG42-4266-1270NE, 12 V, 61:1 gearbox, modeled at the gearbox output.

        Manufacturer output values:
          rated point: 2.94 N.m at 103 rpm (10.786135 rad/s)
          no-load speed: 7000 / 61 rpm (12.017021 rad/s)

        The equivalent 28.702929 N.m stall torque is extrapolated from those
        two output-shaft points.  A 10 percent operating margin limits voltage
        to 10.8 V and continuous output torque to 2.646 N.m.  The published
        2.94 N.m already includes the 61:1 reduction and 72 percent gearbox
        efficiency, so gear remains 1 and efficiency is not applied again.
      -->
      <dcmotor gear="1" ctrlrange="-10.8 10.8"
               nominal="12 28.702929 12.017021"
               saturation="2.646 0 0"/>
    </default>
    <default class="mecanum_roller">
      <!-- Small joint losses approximate the roller bearing drag. -->
      <joint type="hinge" axis="0 0 1" limited="false"
             damping="0.00002" frictionloss="0.0001" armature="0.000001"/>
      <!--
        contype/conaffinity lets rollers contact the floor and chassis but not
        other rollers. friction = sliding, torsional, rolling coefficients.
      -->
      <geom type="capsule" size="0.008 0.015" mass="0.01"
            material="wheel_roller" group="2" contype="2" conaffinity="1"
            priority="1" condim="6" friction="1.2 0.002 0.0002"
            solref="0.003 1" solimp="0.95 0.99 0.001"/>
    </default>
    <default class="caster">
      <geom type="sphere" group="3" size="0.02" rgba="0.7 0.7 0.7 1" contype="1" conaffinity="1" condim="1" priority="1"/>
    </default>
    <!--
      Feetech 12 V smart-servo output properties.

      The actuator force and speed limits use 90 percent of the published
      values for a 10 percent operating margin. Joint damping is calibrated so
      saturated motion reaches the derated no-load speed after the existing
      dry-friction term. Feetech documents the PID as configurable but does not
      publish a fixed factory gain, so the existing SO101 position-loop gains
      and unmeasured armature/friction values remain.
    -->
    <default class="sts3215">
      <geom contype="0" conaffinity="0"/>
      <!-- ST-3215-C018 derated: 2.6477955 N.m, 4.2453955 rad/s. -->
      <joint damping="0.611437854" frictionloss="0.052" armature="0.028"
             actuatorfrcrange="-2.6477955 2.6477955"/>
      <position kp="998.22" kv="2.731" forcerange="-2.6477955 2.6477955"/>
    </default>
    <default class="sts3250">
      <geom contype="0" conaffinity="0"/>
      <!-- ST-3250-C001 derated: 4.4129925 N.m, 7.0862992 rad/s. -->
      <joint damping="0.615411848" frictionloss="0.052" armature="0.028"
             actuatorfrcrange="-4.4129925 4.4129925"/>
      <position kp="998.22" kv="2.731" forcerange="-4.4129925 4.4129925"/>
    </default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" density="0" group="2"/>
    </default>
    <default class="collision">
      <geom contype="1" conaffinity="1" group="3" type="mesh"
            condim="4" solref="0.002 1.0" solimp="0.95 0.99 0.001"/>
    </default>
  </default>

