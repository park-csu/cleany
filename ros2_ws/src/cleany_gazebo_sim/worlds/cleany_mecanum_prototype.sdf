      <plugin filename="ignition-gazebo-mecanum-drive-system" name="ignition::gazebo::systems::MecanumDrive">
        <front_left_joint>front_left_wheel_joint</front_left_joint>
        <front_right_joint>front_right_wheel_joint</front_right_joint>
        <back_left_joint>left_wheel_joint</back_left_joint>
        <back_right_joint>right_wheel_joint</back_right_joint>
        <wheel_separation>0.51</wheel_separation>
        <wheelbase>0.30</wheelbase>
        <wheel_radius>0.0635</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <min_acceleration>-2.0</min_acceleration>
        <max_acceleration>2.0</max_acceleration>
      </plugin>
      <!--
        Publish simulator ground-truth independently of the drive plugin.  This
        keeps the ROS odometry contract available even if the drive system
        changes its internal odometry implementation between Gazebo releases.
      -->
      <plugin filename="ignition-gazebo-odometry-publisher-system" name="ignition::gazebo::systems::OdometryPublisher">
        <odom_frame>odom</odom_frame>
        <robot_base_frame>base_link</robot_base_frame>
        <dimensions>2</dimensions>
        <odom_publish_frequency>50</odom_publish_frequency>
        <odom_topic>/model/cleany_mecanum/odometry</odom_topic>
      </plugin>
      <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher"/>
    </model>
