      <joint name="right_arm_mount" type="fixed"><pose relative_to="base_link">-0.09 0.11 0.395 0 0 3.14159265</pose><parent>base_link</parent><child>right_arm_base</child></joint>
      <joint name="right_rotation_r_joint" type="revolute"><pose relative_to="right_arm_base">0 -0.0452 0.0165 1.5708 0 0</pose><parent>right_arm_base</parent><child>right_rotation_pitch</child><axis><xyz>0 -1 0</xyz><limit><lower>-2.16</lower><upper>2.16</upper></limit></axis></joint>
      <joint name="right_pitch_joint" type="revolute"><pose relative_to="right_rotation_pitch">0 0.1025 0.0306 1.5708 0 0</pose><parent>right_rotation_pitch</parent><child>right_upper_arm</child><axis><xyz>-1 0 0</xyz><limit><lower>-0.22</lower><upper>3.37</upper></limit></axis></joint>
      <joint name="right_elbow_joint" type="revolute"><pose relative_to="right_upper_arm">0 0.11257 0.028 -1.5708 0 0</pose><parent>right_upper_arm</parent><child>right_lower_arm</child><axis><xyz>1 0 0</xyz><limit><lower>-0.22</lower><upper>3.14</upper></limit></axis></joint>
      <joint name="right_wrist_pitch_joint" type="revolute"><pose relative_to="right_lower_arm">0 0.0052 0.1349 -1.5708 0 0</pose><parent>right_lower_arm</parent><child>right_wrist_pitch</child><axis><xyz>1 0 0</xyz><limit><lower>-1.658062849</lower><upper>1.658062729</upper></limit></axis></joint>
      <joint name="right_wrist_roll_joint" type="revolute"><pose relative_to="right_wrist_pitch">0 -0.0601 0 0 1.5708 0</pose><parent>right_wrist_pitch</parent><child>right_fixed_jaw</child><axis><xyz>0 -1 0</xyz><limit><lower>-2.743847297</lower><upper>2.841206309</upper></limit></axis></joint>
      <joint name="right_jaw_joint" type="revolute"><pose relative_to="right_fixed_jaw">-0.0202 -0.0244 0 3.1416 0 3.33</pose><parent>right_fixed_jaw</parent><child>right_moving_jaw</child><axis><xyz>0 0 1</xyz><limit><lower>-0.374532978</lower><upper>1.745329200</upper></limit></axis></joint>

      <plugin filename="ignition-gazebo-mecanum-drive-system" name="ignition::gazebo::systems::MecanumDrive">
        <front_left_joint>front_left_wheel_joint</front_left_joint>
        <front_right_joint>front_right_wheel_joint</front_right_joint>
        <back_left_joint>left_wheel_joint</back_left_joint>
        <back_right_joint>right_wheel_joint</back_right_joint>
        <wheel_separation>0.51</wheel_separation>
        <wheelbase>0.30</wheelbase>
        <wheel_radius>0.0635</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <min_acceleration>-2.0</min_acceleration>
        <max_acceleration>2.0</max_acceleration>
      </plugin>
      <!--
        Publish simulator ground-truth independently of the drive plugin.  This
        keeps the ROS odometry contract available even if the drive system
        changes its internal odometry implementation between Gazebo releases.
      -->
      <plugin filename="ignition-gazebo-odometry-publisher-system" name="ignition::gazebo::systems::OdometryPublisher">
        <odom_frame>odom</odom_frame>
        <robot_base_frame>base_link</robot_base_frame>
        <dimensions>2</dimensions>
        <odom_publish_frequency>50</odom_publish_frequency>
        <odom_topic>/model/cleany_mecanum/odometry</odom_topic>
      </plugin>
      <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher"/>
    </model>
  </world>
</sdf>
